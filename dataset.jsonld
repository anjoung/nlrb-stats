{
  "@context": "https://schema.org/",
  "@type": "Dataset",
  "name": "NLRB Historical Statistical Tables (reconstructed)",
  "description": "Machine-readable reconstruction of the statistical tables in the U.S. National Labor Relations Board Annual Reports (public domain). This release covers fiscal year(s) 1962: 2,511 table cells in long/tidy form, plus per-table CSVs.",
  "url": "index.html",
  "license": "https://www.usa.gov/government-works",
  "isAccessibleForFree": true,
  "creator": {
    "@type": "Organization",
    "name": "NLRB Stats Archive"
  },
  "isBasedOn": "U.S. NLRB Annual Reports (public domain)",
  "temporalCoverage": "1962",
  "dateModified": "2026-06-13",
  "variableMeasured": [
    {
      "@type": "PropertyValue",
      "name": "table_id",
      "description": "Stable id of the source table (year + page + index)."
    },
    {
      "@type": "PropertyValue",
      "name": "fiscal_year",
      "description": "NLRB fiscal year of the Annual Report."
    },
    {
      "@type": "PropertyValue",
      "name": "source_pdf",
      "description": "Source Annual Report PDF filename."
    },
    {
      "@type": "PropertyValue",
      "name": "source_page",
      "description": "Zero-based page index within the source PDF."
    },
    {
      "@type": "PropertyValue",
      "name": "table_title",
      "description": "Table title as printed (may be empty for untitled tables)."
    },
    {
      "@type": "PropertyValue",
      "name": "row_index",
      "description": "Zero-based row position within the table."
    },
    {
      "@type": "PropertyValue",
      "name": "row_label",
      "description": "The row's stub label (left-most column)."
    },
    {
      "@type": "PropertyValue",
      "name": "row_label_footnote_refs",
      "description": "Footnote markers attached to the row label."
    },
    {
      "@type": "PropertyValue",
      "name": "col_index",
      "description": "Zero-based data-column position within the table."
    },
    {
      "@type": "PropertyValue",
      "name": "value_raw",
      "description": "The cell text exactly as extracted, before normalization."
    },
    {
      "@type": "PropertyValue",
      "name": "cell_footnote_refs",
      "description": "Footnote markers attached to the cell."
    },
    {
      "@type": "PropertyValue",
      "name": "parse_uncertainty",
      "description": "Extractor's per-cell uncertainty flag."
    },
    {
      "@type": "PropertyValue",
      "name": "parse_status",
      "description": "Extraction status for the cell."
    },
    {
      "@type": "PropertyValue",
      "name": "is_continuation",
      "description": "True if the table continues a table on a prior page."
    },
    {
      "@type": "PropertyValue",
      "name": "headers_source",
      "description": "Provenance of the column headers."
    },
    {
      "@type": "PropertyValue",
      "name": "value_clean",
      "description": "Cleaned cell value (normalization applied; string)."
    },
    {
      "@type": "PropertyValue",
      "name": "value_num",
      "description": "Numeric value when the cell parsed to a number, else null."
    },
    {
      "@type": "PropertyValue",
      "name": "norm_status",
      "description": "Normalization outcome (ok/recovered/na/non_numeric/ambiguous)."
    },
    {
      "@type": "PropertyValue",
      "name": "unit",
      "description": "Detected unit (none/dollar/percent)."
    }
  ],
  "distribution": [
    {
      "@type": "DataDownload",
      "encodingFormat": "application/vnd.apache.parquet",
      "contentUrl": "data/nlrb_tables_long.parquet"
    },
    {
      "@type": "DataDownload",
      "encodingFormat": "text/csv",
      "contentUrl": "data/nlrb_tables_long.csv.gz"
    },
    {
      "@type": "DataDownload",
      "encodingFormat": "application/json",
      "contentUrl": "catalog.json"
    }
  ]
}